# ──────────────────────────────────────────────────────────────
# Meomul Web — Production Environment Variables
# Set these on your hosting platform (Vercel, Railway, etc.)
# ALL variables are REQUIRED in production — the app will refuse
# to start if any NEXT_PUBLIC_* variable is missing.
# ──────────────────────────────────────────────────────────────

# ── API Endpoints (REQUIRED) ─────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=https://<your-api-app>.azurewebsites.net/graphql
NEXT_PUBLIC_API_URL=https://<your-api-app>.azurewebsites.net
NEXT_PUBLIC_CHAT_SOCKET_URL=https://<your-api-app>.azurewebsites.net

# ── Site (REQUIRED) ──────────────────────────────────────────
# Used for SEO canonical URLs, sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://<your-web-domain>

# ── Build ID (REQUIRED for safe cache busting on deploy) ─────
# Set this in the build environment to a commit SHA or release id.
# Example Azure value: the short git SHA from your CI pipeline.
NEXT_PUBLIC_BUILD_ID=<git-sha-or-release-id>
