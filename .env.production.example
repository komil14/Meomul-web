# ──────────────────────────────────────────────────────────────
# Meomul Web — Production Environment Variables
# Set these on your hosting platform (Vercel, Railway, etc.)
# ALL variables are REQUIRED in production — the app will refuse
# to start if any NEXT_PUBLIC_* variable is missing.
# ──────────────────────────────────────────────────────────────

# ── API Endpoints (REQUIRED) ─────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=https://api.meomul.com/graphql
NEXT_PUBLIC_API_URL=https://api.meomul.com
NEXT_PUBLIC_CHAT_SOCKET_URL=https://api.meomul.com

# ── Site (REQUIRED) ──────────────────────────────────────────
# Used for SEO canonical URLs, sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://meomul.com
