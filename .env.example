# ──────────────────────────────────────────────────────────────
# Meomul Web — Environment Variables
# Copy this file to .env.local and fill in values.
# ──────────────────────────────────────────────────────────────

# ── API Endpoints ─────────────────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/graphql   # GraphQL endpoint
NEXT_PUBLIC_API_URL=http://localhost:3001                # REST API base URL
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3001        # Socket.IO base URL

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000               # Public site URL (for SEO canonical, sitemap, OG tags)

# ── Build ID (required for production deploys) ────────────────
# Next.js does NOT inject this automatically. Set at build time to invalidate
# the Apollo localStorage cache between deploys and prevent stale data.
# In CI/CD: NEXT_PUBLIC_BUILD_ID=$(git rev-parse --short HEAD) npm run build
# Or use the convenience script:  npm run build:prod
NEXT_PUBLIC_BUILD_ID=                                    # Git SHA or timestamp injected at build time
